# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Public site URL (required for production auth email links and password reset)
# Local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production (Vercel) — set to your deployed domain, e.g. https://afrimet.vercel.app
# NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# OpenAI (required for AI meal analysis — Sprint 6+)
OPENAI_API_KEY=your-openai-api-key

# Google OAuth (optional — not required for email/password auth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
